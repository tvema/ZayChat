# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="www.zstate.ru"

# SMTP Settings for sending emails (Gmail)
SMTP_USER="admin@zstate.ru"
SMTP_PASS="ваш_16_значный_пароль_приложения"

# VAPID Keys for Push Notifications (generate with web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# Initial Root User Configurations (used for database bootstrapping)
ROOT_USERNAME="zaqc"
ROOT_FIRST_NAME="Admin"
ROOT_LAST_NAME="User"
ROOT_EMAIL="admin@zstate.ru"
ROOT_PHONE="+1234567890"
ROOT_PASSWORD="zaqc123"